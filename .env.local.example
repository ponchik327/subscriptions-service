# Local dev — copy to .env.local, then: make dev
# Used by make run / make dev / make migrate-*.
# NOT read by docker compose (docker compose reads .env).
# Values here override Makefile defaults and config/config.yaml.
#
# Only deployment-specific values need to be here.
# All other settings live in config/config.yaml.

# ── Secrets / deployment-specific ────────────────────────────────────────────
# Postgres runs in Docker with port 5432 mapped to localhost (make infra-up).
POSTGRES_DSN=postgres://app:app@localhost:5432/subscriptions?sslmode=disable

# Relative path to migrations — overrides the absolute /migrations in config.yaml
# which is only valid inside the Docker container.
POSTGRES_MIGRATIONS_PATH=file://migrations

# ── Optional overrides ────────────────────────────────────────────────────────
# Uncomment only to diverge from config/config.yaml defaults.
# HTTP_PORT=8080
# LOG_LEVEL=debug

# ── Observability (optional) ──────────────────────────────────────────────────
# Uncomment to enable tracing. Start Jaeger separately first:
#   docker run -d -p 16686:16686 -p 4318:4318 jaegertracing/all-in-one:latest
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4318
# OTEL_SERVICE_NAME=subscriptions-service
