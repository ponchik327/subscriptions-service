# Full Docker stack — copy to .env, then: make docker-up
# docker compose reads this file automatically.
#
# Only deployment-specific and secret values go here.
# All other settings live in config/config.yaml.

# ── Secrets / deployment-specific ────────────────────────────────────────────
# "postgres" is the service name inside the docker network.
POSTGRES_DSN=postgres://app:app@postgres:5432/subscriptions?sslmode=disable

# Path to the yaml config file (resolved relative to the container's workdir /).
CONFIG_PATH=./config/config.yaml

# ── Observability (optional) ──────────────────────────────────────────────────
# Uncomment to enable tracing. Jaeger is included in docker-compose.yml and
# accepts OTLP on port 4318. Traces are visible at http://localhost:16686.
# OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4318
# OTEL_SERVICE_NAME=subscriptions-service
